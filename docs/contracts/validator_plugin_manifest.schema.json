{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://purpleaxiom.dev/schemas/validator_plugin_manifest.schema.json",
  "title": "validator_plugin_manifest",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "plugin_id",
    "plugin_version",
    "implements",
    "implements_contract_version",
    "capabilities",
    "supported_inputs",
    "offline_only",
    "determinism"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "pa:validator-plugin-manifest:v1"
    },
    "contract_version": {
      "const": "0.1.0"
    },
    "plugin_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "plugin_version": {
      "type": "string",
      "minLength": 1
    },
    "implements": {
      "const": "pa:validator-plugin-contract:v1"
    },
    "implements_contract_version": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]{2,63}$"
      }
    },
    "supported_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "sigma_rule_yaml",
          "sigma_ast_v1",
          "bridge_ir_v1",
          "compiled_plan_v1",
          "bundle_manifest_v1"
        ]
      }
    },
    "supported_backends": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "backend_id",
          "backend_version_range"
        ],
        "additionalProperties": false,
        "properties": {
          "backend_id": {
            "type": "string",
            "minLength": 1
          },
          "backend_version_range": {
            "type": "string",
            "minLength": 1
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]{2,63}$"
            }
          }
        }
      }
    },
    "offline_only": {
      "type": "boolean"
    },
    "determinism": {
      "type": "object",
      "required": [
        "stable_output",
        "emits_contract"
      ],
      "additionalProperties": false,
      "properties": {
        "stable_output": {
          "const": true
        },
        "emits_contract": {
          "const": "ci_gate_findings"
        }
      }
    }
  }
}
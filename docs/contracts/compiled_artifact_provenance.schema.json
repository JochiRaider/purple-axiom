{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pa:compiled_artifact_provenance.schema:v1",
  "title": "Compiled Artifact Provenance Envelope (pa:compiled_artifact_provenance:v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "schema_version",
    "pass_id",
    "inputs",
    "toolchain",
    "compilation_unit_sha256",
    "output_basis",
    "output_payload_sha256"
  ],
  "properties": {
    "contract_version": {
      "const": "0.1.0"
    },
    "schema_version": {
      "const": "pa:compiled_artifact_provenance:v1"
    },
    "pass_id": {
      "type": "string",
      "description": "Producing pass identifier (stable, versioned).",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$",
      "minLength": 1,
      "maxLength": 64
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/input_pin"
      }
    },
    "toolchain": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/toolchain_pin"
      }
    },
    "options": {
      "type": "object",
      "description": "Deterministic compilation options that affect output bytes. Must not include volatile values.",
      "additionalProperties": true
    },
    "compilation_unit_sha256": {
      "$ref": "#/$defs/digest_sha256"
    },
    "output_basis": {
      "type": "string",
      "enum": [
        "artifact_without_compiled_provenance_v1"
      ]
    },
    "output_payload_sha256": {
      "$ref": "#/$defs/digest_sha256"
    }
  },
  "$defs": {
    "digest_sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "Canonical SHA-256 digest string (sha256:<lowercase_hex>)."
    },
    "rel_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$",
      "description": "Relative POSIX-style path. Must not be absolute, contain backslashes, or contain '..' segments."
    },
    "input_pin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "digest_sha256"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"
        },
        "digest_sha256": {
          "$ref": "#/$defs/digest_sha256"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "contract_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "path": {
          "$ref": "#/$defs/rel_path"
        }
      }
    },
    "toolchain_pin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_id",
        "tool_version"
      ],
      "properties": {
        "tool_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "tool_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "digest_sha256": {
          "$ref": "#/$defs/digest_sha256"
        },
        "capabilities_sha256": {
          "$ref": "#/$defs/digest_sha256"
        }
      }
    }
  }
}
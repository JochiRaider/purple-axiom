{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://purpleaxiom.dev/schemas/fixture_registry.schema.json",
  "title": "fixture_registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_version",
    "fixtures"
  ],
  "properties": {
    "schema_version": {
      "const": "pa:fixture-registry:v1"
    },
    "contract_version": {
      "const": "0.1.0"
    },
    "fixtures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fixture"
      }
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$"
    },
    "posix_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\\\]*$"
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "fixture_version",
        "purpose",
        "formats",
        "root_path",
        "provenance",
        "license",
        "integrity",
        "expected_outcomes"
      ],
      "properties": {
        "fixture_id": {
          "$ref": "#/$defs/uuid"
        },
        "fixture_version": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "enum": [
            "benign",
            "malicious",
            "mixed"
          ]
        },
        "formats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "bdp",
              "parquet_ocsf",
              "jsonl",
              "evtx"
            ]
          }
        },
        "root_path": {
          "$ref": "#/$defs/posix_path"
        },
        "paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/posix_path"
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "created_by",
            "created_at"
          ],
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "source_uri": {
              "type": "string",
              "minLength": 1
            },
            "created_by": {
              "type": "string",
              "minLength": 1
            },
            "created_at": {
              "type": "string",
              "format": "date"
            },
            "environment": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "spdx_id"
          ],
          "properties": {
            "spdx_id": {
              "type": "string",
              "minLength": 1
            },
            "notice": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "integrity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "checksums_path"
          ],
          "properties": {
            "checksums_path": {
              "$ref": "#/$defs/posix_path"
            },
            "signature_path": {
              "$ref": "#/$defs/posix_path"
            }
          }
        },
        "expected_outcomes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expected_outcome"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "expected_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detection_id",
        "assertions"
      ],
      "properties": {
        "detection_id": {
          "type": "string",
          "minLength": 1
        },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/assertion"
          }
        }
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "match_count_exact",
            "match_count_range",
            "field_present",
            "no_matches"
          ]
        },
        "value": {
          "type": "integer",
          "minimum": 0
        },
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "max": {
          "type": "integer",
          "minimum": 0
        },
        "field": {
          "type": "string",
          "minLength": 1
        }
      },
      "oneOf": [
        {
          "properties": {
            "kind": {
              "const": "match_count_exact"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "properties": {
            "kind": {
              "const": "match_count_range"
            }
          },
          "required": [
            "kind",
            "min",
            "max"
          ]
        },
        {
          "properties": {
            "kind": {
              "const": "field_present"
            }
          },
          "required": [
            "kind",
            "field"
          ]
        },
        {
          "properties": {
            "kind": {
              "const": "no_matches"
            }
          },
          "required": [
            "kind"
          ]
        }
      ]
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pa:contract-validation-report:v1",
  "title": "Purple Axiom Contract Validation Report (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "schema_version",
    "run_id",
    "stage_id",
    "generated_at_utc",
    "max_errors_per_artifact",
    "artifacts"
  ],
  "properties": {
    "contract_version": { "const": "0.1.0" },
    "schema_version": { "const": "pa:contract-validation-report:v1" },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "stage_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "max_errors_per_artifact": {
      "type": "integer",
      "minimum": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_path",
          "contract_id",
          "contract_version",
          "status",
          "errors_truncated",
          "errors"
        ],
        "properties": {
          "artifact_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "contract_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "contract_version": { "type": "string", "minLength": 1, "maxLength": 64 },
          "status": { "type": "string", "enum": ["valid", "invalid"] },
          "errors_truncated": { "type": "boolean" },
          "errors": {
            "type": "array",
            "items": { "$ref": "#/$defs/error_entry" }
          }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "diagnostic_record.schema.json" },
          {
            "type": "object",
            "required": ["reason_domain"],
            "properties": { "reason_domain": { "const": "contract_validation_report" } }
          }
        ]
      }
    }
  },
  "$defs": {
    "error_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_path",
        "contract_id",
        "instance_path",
        "schema_path",
        "message"
      ],
      "properties": {
        "artifact_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "contract_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "error_code": { "type": "string", "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$", "maxLength": 128 },
        "instance_path": { "type": "string", "minLength": 0, "maxLength": 4096 },
        "schema_path": { "type": "string", "minLength": 0, "maxLength": 4096 },
        "keyword": { "type": "string", "minLength": 1, "maxLength": 128 },
        "message": { "type": "string", "minLength": 1, "maxLength": 8192 },
        "line_number": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/contracts/bridge_compiled_plan.schema.json",
  "title": "Purple Axiom Sigma-to-OCSF Bridge Compiled Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "rule_id",
    "sigma_ast",
    "rule_sha256",
    "mapping_pack_sha256",
    "backend",
    "executable"
  ],
  "properties": {
    "contract_version": {
      "const": "0.1.0"
    },

    "rule_id": {
      "type": "string",
      "minLength": 1,
      "description": "Sigma rule identifier as selected for the run (typically Sigma 'id')."
    },

    "sigma_ast": {
      "$ref": "sigma_ast_v1.schema.json",
      "description": "Parsed Sigma AST (sigma_ast_v1). Required even when executable=false."
    },

    "rule_sha256": {
      "$ref": "#/$defs/digest_sha256_v1",
      "description": "Canonical digest string over canonical Sigma rule bytes (see 060_detection_sigma.md)."
    },

    "mapping_pack_sha256": {
      "$ref": "#/$defs/digest_sha256_v1",
      "description": "Digest string pinning the mapping pack snapshot used for compilation."
    },

    "compiled_provenance": {
      "$ref": "compiled_artifact_provenance.schema.json",
      "description": "Optional compiled artifact provenance envelope. Required when compile_cache_dir is used."
    },

    "executable": {
      "type": "boolean",
      "description": "Whether the rule successfully compiled to a backend plan and is eligible for evaluation."
    },

    "non_executable_reason": {
      "$ref": "#/$defs/non_executable_reason_v1",
      "description": "Required when executable=false."
    },

    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "settings"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_\\-]*$",
          "description": "Backend identifier (example: native_pcre2)."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Backend implementation version pin (recommended: pipeline_version or backend semver)."
        },
        "settings": {
          "type": "object",
          "additionalProperties": true,
          "description": "Determinism-relevant backend settings (must include all settings that affect output/matches)."
        },
        "plan_kind": {
          "type": "string",
          "minLength": 1,
          "description": "Backend plan kind identifier (v0.1: pa_eval_v1). Required when executable=true."
        },
        "plan": {
          "type": "object",
          "additionalProperties": true,
          "description": "Backend plan payload. Required when executable=true."
        }
      }
    },

    "compilation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "routed_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "class_uids"
          ],
          "properties": {
            "class_uids": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1
              },
              "description": "OCSF class_uid scope selected by the router. Empty when unroutable."
            },
            "filters": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ocsf_filter_v1"
              },
              "description": "Optional producer/source predicates (conjunction)."
            }
          }
        },

        "field_resolution": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field_resolution_v1"
          },
          "description": "Per-field mapping/fallback resolution summary (optional)."
        },

        "fallback_used": {
          "type": "boolean",
          "default": false,
          "description": "True if compilation required raw.* fallback (subject to config gates)."
        },

        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },

    "extensions": {
      "type": "object",
      "additionalProperties": true
    },

    "placeholder": {
      "$ref": "#/$defs/pa_placeholder_v1"
    }
  },

  "allOf": [
    {
      "if": {
        "properties": {
          "executable": {
            "const": true
          }
        },
        "required": [
          "executable"
        ]
      },
      "then": {
        "properties": {
          "non_executable_reason": false,
          "backend": {
            "required": [
              "plan_kind",
              "plan"
            ]
          },
          "compilation": {
            "properties": {
              "routed_scope": {
                "properties": {
                  "class_uids": {
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      },
      "else": {
        "required": [
          "non_executable_reason"
        ],
        "properties": {
          "backend": {
            "properties": {
              "plan_kind": false,
              "plan": false
            }
          }
        }
      }
    },

    {
      "if": {
        "properties": {
          "compiled_provenance": {
            "type": "object"
          }
        },
        "required": [
          "compiled_provenance"
        ]
      },
      "then": {
        "properties": {
          "compiled_provenance": {
            "properties": {
              "pass_id": {
                "const": "detection.bridge.compiled_plans.emit"
              }
            }
          }
        }
      }
    }
  ],

  "$defs": {
    "digest_sha256_v1": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },

    "non_executable_reason_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason_domain",
        "reason_code",
        "explanation"
      ],
      "properties": {
        "reason_domain": {
          "type": "string",
          "const": "bridge_compiled_plan"
        },
        "reason_code": {
          "type": "string",
          "enum": [
            "unroutable_logsource",
            "unmapped_field",
            "raw_fallback_disabled",
            "ambiguous_field_alias",
            "unsupported_modifier",
            "unsupported_operator",
            "unsupported_regex",
            "unsupported_value_type",
            "unsupported_correlation",
            "unsupported_aggregation",
            "backend_compile_error",
            "backend_eval_error"
          ]
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },

    "ocsf_filter_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "op"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "type": "string",
          "enum": [
            "eq",
            "neq",
            "in",
            "nin",
            "exists",
            "contains",
            "prefix",
            "suffix",
            "regex"
          ]
        },
        "value": {},
        "notes": {
          "type": "string"
        }
      }
    },

    "field_resolution_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sigma_field",
        "resolution"
      ],
      "properties": {
        "sigma_field": {
          "type": "string",
          "minLength": 1
        },
        "resolution": {
          "type": "string",
          "enum": [
            "mapped",
            "raw_fallback",
            "unmapped"
          ]
        },
        "expr": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },

    "pa_placeholder_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "placeholder_version",
        "handling",
        "reason_code",
        "reason_domain"
      ],
      "properties": {
        "placeholder_version": {
          "type": "string",
          "const": "pa.placeholder.v1"
        },
        "handling": {
          "type": "string",
          "enum": [
            "withheld",
            "quarantined",
            "absent"
          ]
        },
        "reason_code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "reason_domain": {
          "type": "string",
          "const": "artifact_placeholder"
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "handling": {
                "const": "absent"
              }
            },
            "required": [
              "handling"
            ]
          },
          "then": {
            "properties": {
              "sha256": false
            }
          }
        }
      ]
    }
  }
}

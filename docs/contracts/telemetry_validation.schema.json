{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://purple-axiom.local/schemas/telemetry_validation.schema.json",
  "title": "Purple Axiom Telemetry Validation Summary",
  "description": "Contract for runs/<run_id>/logs/telemetry_validation.json. Records per-asset telemetry validation checks and evidence pointers sufficient to reproduce gating decisions (for example, raw Windows Event Log canary location).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "run_id",
    "generated_at_utc",
    "assets"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Schema contract version for this artifact."
    },
    "run_id": {
      "type": "string",
      "description": "Run identifier (must match the enclosing runs/<run_id>/ folder name)."
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when this summary was generated (RFC 3339)."
    },
    "capture_window": {
      "$ref": "#/$defs/capture_window"
    },
    "windows_eventlog_raw_mode": {
      "$ref": "#/$defs/windows_eventlog_raw_mode_evidence"
    },
    "agent_liveness": {
      "$ref": "#/$defs/agent_liveness_evidence"
    },
    "baseline_profile": {
      "$ref": "#/$defs/baseline_profile_evidence"
    },
    "windows_eventlog_raw_xml": {
      "$ref": "#/$defs/windows_eventlog_raw_xml_evidence"
    },
    "assets": {
      "type": "array",
      "description": "Per-asset telemetry validation results. Producers SHOULD sort by asset_id (UTF-8 byte order) for determinism.",
      "items": {
        "$ref": "#/$defs/asset_result"
      }
    },
    "extensions": {
      "type": "object",
      "description": "Forward-compatible extension point for additional producer data.",
      "additionalProperties": true
    },
    "placeholder": {
      "$ref": "#/$defs/pa_placeholder_v1"
    }
  },
  "$defs": {
    "capture_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_time_utc",
        "end_time_utc",
        "correlation_marker_strategy"
      ],
      "properties": {
        "start_time_utc": {
          "type": "string",
          "format": "date-time",
          "description": "Inclusive lower bound of the telemetry validation window (RFC 3339 UTC)."
        },
        "end_time_utc": {
          "type": "string",
          "format": "date-time",
          "description": "Exclusive upper bound of the telemetry validation window (RFC 3339 UTC)."
        },
        "correlation_marker_strategy": {
          "type": "object",
          "description": "Description of correlation markers used to join layers (MAY be empty).",
          "additionalProperties": true
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "asset_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "checks"
      ],
      "properties": {
        "asset_id": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "description": "Validation checks for the asset. Producers SHOULD sort by check_id (UTF-8 byte order) for determinism.",
          "items": {
            "$ref": "#/$defs/check_result"
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "check_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "status"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "description": "Stable identifier for the check (for example, telemetry.windows_eventlog.raw_mode)."
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "failed",
            "skipped"
          ]
        },
        "reason_code": {
          "type": "string",
          "description": "Stable token explaining failure or skip."
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "canary_observed_at": {
              "$ref": "#/$defs/canary_observed_at"
            },
            "clock_sync": {
              "$ref": "#/$defs/clock_sync_evidence"
            },
            "extensions": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "failed"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "required": [
              "reason_code"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "check_id": {
                "const": "telemetry.windows_eventlog.raw_mode"
              }
            },
            "required": [
              "check_id"
            ]
          },
          "then": {
            "allOf": [
              {
                "if": {
                  "properties": {
                    "status": {
                      "const": "failed"
                    }
                  },
                  "required": [
                    "status"
                  ]
                },
                "then": {
                  "properties": {
                    "reason_code": {
                      "enum": [
                        "winlog_raw_missing",
                        "winlog_rendering_detected"
                      ]
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "status": {
                      "const": "success"
                    }
                  },
                  "required": [
                    "status"
                  ]
                },
                "then": {
                  "required": [
                    "evidence"
                  ],
                  "properties": {
                    "evidence": {
                      "required": [
                        "canary_observed_at"
                      ]
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "status": {
                      "const": "failed"
                    },
                    "reason_code": {
                      "const": "winlog_rendering_detected"
                    }
                  },
                  "required": [
                    "status",
                    "reason_code"
                  ]
                },
                "then": {
                  "required": [
                    "evidence"
                  ],
                  "properties": {
                    "evidence": {
                      "required": [
                        "canary_observed_at"
                      ]
                    }
                  }
                }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "check_id": {
                "const": "telemetry.clock_sync"
              }
            },
            "required": [
              "check_id"
            ]
          },
          "then": {
            "allOf": [
              {
                "if": {
                  "properties": {
                    "status": {
                      "const": "failed"
                    }
                  },
                  "required": [
                    "status"
                  ]
                },
                "then": {
                  "required": [
                    "reason_code",
                    "evidence"
                  ],
                  "properties": {
                    "reason_code": {
                      "enum": [
                        "clock_offset_exceeded",
                        "clock_offset_unmeasurable"
                      ]
                    },
                    "evidence": {
                      "required": [
                        "clock_sync"
                      ]
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "status": {
                      "const": "success"
                    }
                  },
                  "required": [
                    "status"
                  ]
                },
                "then": {
                  "required": [
                    "evidence"
                  ],
                  "properties": {
                    "evidence": {
                      "required": [
                        "clock_sync"
                      ],
                      "properties": {
                        "clock_sync": {
                          "$ref": "#/$defs/clock_sync_measured_evidence"
                        }
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "status": {
                      "const": "failed"
                    },
                    "reason_code": {
                      "const": "clock_offset_exceeded"
                    }
                  },
                  "required": [
                    "status",
                    "reason_code"
                  ]
                },
                "then": {
                  "properties": {
                    "evidence": {
                      "properties": {
                        "clock_sync": {
                          "$ref": "#/$defs/clock_sync_measured_evidence"
                        }
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "status": {
                      "const": "failed"
                    },
                    "reason_code": {
                      "const": "clock_offset_unmeasurable"
                    }
                  },
                  "required": [
                    "status",
                    "reason_code"
                  ]
                },
                "then": {
                  "properties": {
                    "evidence": {
                      "properties": {
                        "clock_sync": {
                          "$ref": "#/$defs/clock_sync_unmeasurable_evidence"
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      ]
    },
    "clock_sync_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "t0_ms",
        "t1_ms",
        "t2_ms",
        "round_trip_ms",
        "offset_ms"
      ],
      "properties": {
        "t0_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Orchestrator send time (milliseconds)."
        },
        "t1_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Asset clock reading at request handling (milliseconds)."
        },
        "t2_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Orchestrator receive time (milliseconds)."
        },
        "round_trip_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Round-trip time for the sample (milliseconds)."
        },
        "offset_ms": {
          "type": "integer",
          "description": "Clock offset sample (asset - orchestrator_midpoint), in milliseconds."
        },
        "selected": {
          "type": "boolean",
          "description": "True when this sample was selected as the representative sample for the check."
        }
      }
    },
    "clock_sync_measured_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_abs_offset_ms",
        "offset_ms",
        "abs_offset_ms"
      ],
      "properties": {
        "max_abs_offset_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Configured maximum allowed absolute offset (milliseconds)."
        },
        "offset_ms": {
          "type": "integer",
          "description": "Measured offset in milliseconds (positive means asset is ahead of orchestrator)."
        },
        "abs_offset_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Absolute value of offset_ms, in milliseconds."
        },
        "round_trip_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Round-trip time for the selected sample (milliseconds)."
        },
        "method": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Stable method identifier (for example, ntp_midpoint_v1)."
        },
        "measured_at_utc": {
          "type": "string",
          "format": "date-time",
          "description": "UTC timestamp when the representative sample was taken (RFC 3339)."
        },
        "samples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/clock_sync_sample"
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "clock_sync_unmeasurable_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_abs_offset_ms",
        "error_code"
      ],
      "properties": {
        "max_abs_offset_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Configured maximum allowed absolute offset (milliseconds)."
        },
        "error_code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Stable token for probe failure (for example, probe_timeout, probe_unavailable, parse_error)."
        },
        "error_detail": {
          "type": "string",
          "maxLength": 4096,
          "description": "Optional diagnostic detail."
        },
        "method": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Stable method identifier (for example, ntp_midpoint_v1)."
        },
        "measured_at_utc": {
          "type": "string",
          "format": "date-time",
          "description": "UTC timestamp when the probe attempt occurred (RFC 3339)."
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "clock_sync_evidence": {
      "oneOf": [
        {
          "$ref": "#/$defs/clock_sync_measured_evidence"
        },
        {
          "$ref": "#/$defs/clock_sync_unmeasurable_evidence"
        }
      ]
    },
    "windows_eventlog_raw_mode_canary_observed_at_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "channel",
        "path"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "description": "Asset identifier (agent/endpoint) that observed the canary."
        },
        "channel": {
          "type": "string",
          "description": "Windows Event Log channel where the canary was observed (for example, Application, Security, Microsoft-Windows-Sysmon/Operational)."
        },
        "path": {
          "type": "string",
          "description": "Run-relative path (POSIX separators) to the concrete raw artifact or dataset file where the canary was observed.",
          "pattern": "^[^\\\\]*$"
        },
        "event_id": {
          "type": "string",
          "description": "Optional canonical event identifier (for example, metadata.event_id) when resolvable."
        },
        "row_locator": {
          "type": "object",
          "description": "Optional minimal locator sufficient to re-query a dataset deterministically (for example, Parquet row group + row index).",
          "additionalProperties": true
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "windows_eventlog_raw_mode_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "performed",
        "observed"
      ],
      "properties": {
        "performed": {
          "type": "boolean",
          "description": "True when the raw-mode canary check was executed."
        },
        "observed": {
          "type": "boolean",
          "description": "True when the canary was captured and passed the raw-mode policy checks."
        },
        "canary_observed_at": {
          "$ref": "#/$defs/windows_eventlog_raw_mode_canary_observed_at_v1"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "agent_liveness_asset_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "observed"
      ],
      "properties": {
        "asset_id": {
          "type": "string"
        },
        "observed": {
          "type": "boolean"
        },
        "first_seen": {
          "type": "string",
          "format": "date-time",
          "description": "First observed heartbeat timestamp (RFC 3339 UTC)."
        },
        "last_seen": {
          "type": "string",
          "format": "date-time",
          "description": "Last observed heartbeat timestamp (RFC 3339 UTC)."
        },
        "evidence_path": {
          "type": "string",
          "description": "Run-relative path (POSIX separators) to a supporting evidence artifact (for example, a pruned metrics capture).",
          "pattern": "^[^\\\\]*$"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "observed": {
                "const": false
              }
            },
            "required": [
              "observed"
            ]
          },
          "then": {
            "properties": {
              "first_seen": false,
              "last_seen": false
            }
          }
        }
      ]
    },
    "agent_liveness_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assets"
      ],
      "properties": {
        "startup_grace_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "required_metric_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assets": {
          "type": "array",
          "description": "Per-asset agent liveness results. Producers SHOULD sort by asset_id (UTF-8 byte order) for determinism.",
          "items": {
            "$ref": "#/$defs/agent_liveness_asset_v1"
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "baseline_profile_signal_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "source_type",
        "min_count",
        "observed_count",
        "passed"
      ],
      "properties": {
        "signal_id": {
          "type": "string"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "windows_eventlog",
            "osquery"
          ]
        },
        "match": {
          "type": "object",
          "description": "Echo of the profile match predicate (implementation-defined shape).",
          "additionalProperties": true
        },
        "min_count": {
          "type": "integer",
          "minimum": 0
        },
        "observed_count": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "boolean"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "baseline_profile_asset_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id"
      ],
      "properties": {
        "asset_id": {
          "type": "string"
        },
        "matched_profile_id": {
          "type": "string",
          "description": "Profile id selected for the asset (when a match exists)."
        },
        "signals": {
          "type": "array",
          "description": "Per-signal baseline profile evaluations. Producers SHOULD sort by signal_id (UTF-8 byte order) for determinism.",
          "items": {
            "$ref": "#/$defs/baseline_profile_signal_v1"
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "baseline_profile_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_path",
        "assets"
      ],
      "properties": {
        "profile_path": {
          "type": "string",
          "description": "Run-relative path (POSIX separators) to the baseline profile snapshot file.",
          "pattern": "^[^\\\\]*$"
        },
        "profile_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "assets": {
          "type": "array",
          "description": "Per-asset baseline profile results. Producers SHOULD sort by asset_id (UTF-8 byte order) for determinism.",
          "items": {
            "$ref": "#/$defs/baseline_profile_asset_v1"
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "windows_eventlog_raw_xml_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wineventlog_used_log_record_original_total",
        "wineventlog_raw_unavailable_total",
        "wineventlog_raw_malformed_total",
        "fail_mode"
      ],
      "properties": {
        "wineventlog_used_log_record_original_total": {
          "type": "integer",
          "minimum": 0
        },
        "wineventlog_raw_unavailable_total": {
          "type": "integer",
          "minimum": 0
        },
        "wineventlog_raw_malformed_total": {
          "type": "integer",
          "minimum": 0
        },
        "fail_mode": {
          "type": "string",
          "enum": [
            "fail_closed",
            "warn_and_skip"
          ]
        },
        "reason_code": {
          "type": "string",
          "enum": [
            "raw_xml_unavailable"
          ]
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "canary_observed_at": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel",
        "path"
      ],
      "properties": {
        "channel": {
          "type": "string",
          "description": "Windows Event Log channel where the canary was observed (for example, Application, Security, Microsoft-Windows-Sysmon/Operational)."
        },
        "path": {
          "type": "string",
          "description": "Run-relative path (POSIX separators) to the concrete raw artifact or dataset file where the canary was observed.",
          "pattern": "^[^\\\\]*$"
        },
        "row_locator": {
          "type": "object",
          "description": "Optional minimal locator sufficient to re-query a dataset deterministically (for example, event_record_id and provider).",
          "additionalProperties": true
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "pa_placeholder_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "placeholder_version",
        "handling",
        "reason_code",
        "reason_domain"
      ],
      "properties": {
        "placeholder_version": {
          "type": "string",
          "const": "pa.placeholder.v1"
        },
        "handling": {
          "type": "string",
          "enum": [
            "withheld",
            "quarantined",
            "absent"
          ]
        },
        "reason_code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "reason_domain": {
          "type": "string",
          "const": "artifact_placeholder"
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "handling": {
                "const": "absent"
              }
            },
            "required": [
              "handling"
            ]
          },
          "then": {
            "properties": {
              "sha256": false
            }
          }
        }
      ]
    }
  }
}
